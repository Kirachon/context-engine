      "mode": "all"
    },
    {
      "id": "parity.performance.query_latency_p95",
      "kind": "json_path_compare",
      "description": "Current PR bench candidate p95 should remain within the historical candidate envelope.",
      "path": "artifacts/bench/pr-candidate.json",
      "json_path": "payload.timing.p95_ms",
      "comparator": "lte",
      "threshold": 100
