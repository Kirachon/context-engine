      "kind": "file_exists",
      "description": "Rollback drill receipt must be present.",
      "path": "docs/rollout-evidence/2026-03-04/ws21-rollback-drill-log.md"
    },
    {
      "id": "parity.ops.no_legacy_scan_receipt_present",
      "kind": "command_exit_zero",
      "description": "Current no-legacy scan must pass.",
      "command": "npm run -s ci:check:no-legacy-provider"
    }
