    {
      "id": "parity.search.rank_stability",
      "kind": "command_exit_zero",
      "description": "Provider-backed semantic search behavior must remain stable.",
      "command": "npm test -- --runInBand tests/serviceClient.test.ts"
    },
    {
      "id": "parity.search.result_consistency",
      "kind": "command_exit_zero",
      "description": "Service client search regression suite acts as the first consistency receipt.",
      "command": "npm test -- --runInBand tests/serviceClient.test.ts"
    },
    {
      "id": "parity.search.query_behavior_match",
      "kind": "command_exit_zero",
      "description": "Search tool behavior must match existing query expectations.",
      "command": "npm test -- --runInBand tests/tools/search.test.ts"
    },
    {
