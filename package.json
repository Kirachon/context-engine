{
  "name": "context-engine-mcp-server",
  "version": "1.9.0",
  "description": "MCP server implementation for local context engine workflows with openai-session runtime, planning, and execution features",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "context-engine-mcp": "./bin/context-engine-mcp.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "tsx src/index.ts",
    "start:dist": "node --import tsx dist/index.js",
    "prepare": "npm run build",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "verify": "node verify-setup.js",
    "index": "tsx src/index.ts --workspace . --index",
    "inspector": "npx @modelcontextprotocol/inspector tsx src/index.ts --workspace .",
    "bench": "tsx scripts/bench.ts",
    "bench:compare": "node --import tsx scripts/ci/bench-compare.ts",
    "bench:pr": "npm run bench:compare -- --baseline bench-baseline.json --candidate bench-candidate.json --metric payload.timing.p95_ms --max-regression-pct 10 --max-regression-abs 25",
    "bench:ci:pr": "node --import tsx scripts/ci/run-bench-suite.ts --mode pr",
    "bench:ci:nightly": "node --import tsx scripts/ci/run-bench-suite.ts --mode nightly",
    "bench:ci:release": "node --import tsx scripts/ci/release-bench.ts",
    "ci:matrix:migrated-families": "node --import tsx scripts/ci/run-migrated-family-matrix.ts",
    "ci:check:stale-cache-guards": "node --import tsx scripts/ci/check-stale-cache-guards.ts",
    "ci:check:retrieval-dependency-boundary": "node --import tsx scripts/ci/check-retrieval-provider-boundary.ts",
    "ci:check:auggie-capability-parity": "npm run -s ci:generate:auggie-parity-report && node --import tsx scripts/ci/check-auggie-capability-parity.ts --report artifacts/bench/retrieval-parity-pr.json --matrix config/ci/auggie-capability-matrix.json --out artifacts/bench/auggie-capability-parity-gate.json",
    "ci:check:no-legacy-auggie": "node --import tsx scripts/ci/check-auggie-no-legacy-references.ts --allowlist config/ci/auggie-no-legacy-allowlist.txt",
    "ci:check:retrieval-config-precedence": "node --import tsx scripts/ci/check-retrieval-config-precedence.ts",
    "ci:check:retrieval-provider-dist-parity": "node --import tsx scripts/ci/check-retrieval-provider-dist-parity.ts",
    "ci:check:ws-owner-assignment-lock": "node --import tsx scripts/ci/check-ws-owner-assignment-lock.ts",
    "ci:check:governance-artifacts": "node --import tsx scripts/ci/check-governance-artifacts.ts",
    "ci:check:ws21-rollback-drill": "node --import tsx scripts/ci/check-ws21-rollback-drill.ts docs/WS21_ROLLBACK_DRILL_TEMPLATE.md docs/WS21_ROLLBACK_DRILL_SAMPLE.md",
    "ci:generate:auggie-parity-report": "node --import tsx scripts/ci/generate-auggie-parity-report.ts --fixture-pack config/ci/auggie-parity-fixture-pack.json --matrix config/ci/auggie-capability-matrix.json --out artifacts/bench/retrieval-parity-pr.json",
    "ci:archive:auggie-parity-history": "node --import tsx scripts/ci/archive-auggie-parity-history.ts --artifact artifacts/bench/auggie-capability-parity-gate.json --history-dir artifacts/bench/auggie-parity-history",
    "ci:check:auggie-capability-parity:strict": "npm run -s ci:check:auggie-capability-parity && npm run -s ci:archive:auggie-parity-history && node --import tsx scripts/ci/check-auggie-capability-parity.ts --report artifacts/bench/retrieval-parity-pr.json --matrix config/ci/auggie-capability-matrix.json --out artifacts/bench/auggie-capability-parity-gate.json --require-consecutive 3 --history-dir artifacts/bench/auggie-parity-history"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "openai-session",
    "context-engine",
    "semantic-search"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "chokidar": "^3.5.3",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "minimatch": "^10.1.1",
    "tsx": "^4.21.0",
    "yaml": "^2.3.0"
  },
  "devDependencies": {
    "@types/chokidar": "^2.1.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.3",
    "jest": "^30.2.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.0"
  }
}
