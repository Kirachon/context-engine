{
  "name": "context-engine-mcp-server",
  "version": "1.9.0",
  "description": "MCP server implementation for local context engine workflows with openai-session runtime, planning, and execution features",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "context-engine-mcp": "./bin/context-engine-mcp.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "tsx src/index.ts",
    "start:dist": "node --import tsx dist/index.js",
    "prepare": "npm run build",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "install:polyglot-grammars": "npm install --no-save tree-sitter-python@0.21.0 tree-sitter-go@0.21.2 tree-sitter-rust@0.21.0 tree-sitter-java@0.21.0 tree-sitter-c-sharp@0.21.3",
    "verify": "node verify-setup.js",
    "index": "tsx src/index.ts --workspace . --index",
    "inspector": "npx @modelcontextprotocol/inspector tsx src/index.ts --workspace .",
    "bench": "tsx scripts/bench.ts",
    "bench:compare": "node --import tsx scripts/ci/bench-compare.ts",
    "bench:pr": "npm run bench:compare -- --baseline bench-baseline.json --candidate bench-candidate.json --metric payload.timing.p95_ms --max-regression-pct 10 --max-regression-abs 25",
    "bench:ci:pr": "node --import tsx scripts/ci/run-bench-suite.ts --mode pr",
    "bench:ci:nightly": "node --import tsx scripts/ci/run-bench-suite.ts --mode nightly",
    "bench:ci:release": "node --import tsx scripts/ci/release-bench.ts",
    "ci:check:mcp-smoke": "node --import tsx scripts/ci/mcp-smoke.ts",
    "ci:matrix:migrated-families": "node --import tsx scripts/ci/run-migrated-family-matrix.ts",
    "ci:check:stale-cache-guards": "node --import tsx scripts/ci/check-stale-cache-guards.ts",
    "ci:check:brand-detachment": "node --import tsx scripts/ci/check-brand-detachment.ts --allowlist config/ci/brand-compat-allowlist.txt",
    "ci:check:retrieval-dependency-boundary": "node --import tsx scripts/ci/check-retrieval-provider-boundary.ts",
    "ci:check:legacy-capability-parity": "npm run -s ci:generate:legacy-capability-parity-report && node --import tsx scripts/ci/check-legacy-capability-parity.ts --report artifacts/bench/retrieval-parity-pr.json --matrix config/ci/legacy-capability-matrix.json --out artifacts/bench/legacy-capability-parity-gate.json",
    "ci:check:no-legacy-provider": "node --import tsx scripts/ci/check-legacy-provider-references.ts --allowlist config/ci/legacy-provider-no-legacy-allowlist.txt",
    "ci:check:retrieval-config-precedence": "node --import tsx scripts/ci/check-retrieval-config-precedence.ts",
    "ci:check:retrieval-provider-dist-parity": "node --import tsx scripts/ci/check-retrieval-provider-dist-parity.ts",
    "ci:check:ws-owner-assignment-lock": "node --import tsx scripts/ci/check-ws-owner-assignment-lock.ts",
    "ci:generate:r7-governance-registers": "node --import tsx scripts/ci/generate-r7-governance-registers.ts",
    "ci:check:r7-split-risk-registers": "node --import tsx scripts/ci/check-r7-split-risk-registers.ts --delivery docs/templates/r7-delivery-risk-register.template.json --runtime docs/templates/r7-runtime-risk-register.template.json --ignore-cadence",
    "ci:check:r7-split-risk-registers:governance": "npm run -s ci:generate:r7-governance-registers && node --import tsx scripts/ci/check-r7-split-risk-registers.ts",
    "ci:check:r9-recommendation-import": "node --import tsx scripts/ci/check-r9-recommendation-import.ts --known-id R6",
    "ci:check:review-timeout-contract": "node --import tsx scripts/ci/check-review-timeout-contract.ts",
    "ci:check:review-auto-timeout-smoke": "node --import tsx scripts/ci/review-auto-timeout-smoke.ts",
    "ci:check:governance-artifacts": "node --import tsx scripts/ci/check-governance-artifacts.ts",
    "ci:check:ws21-rollback-drill": "node --import tsx scripts/ci/check-ws21-rollback-drill.ts docs/WS21_ROLLBACK_DRILL_TEMPLATE.md docs/WS21_ROLLBACK_DRILL_SAMPLE.md",
    "ci:generate:legacy-capability-parity-report": "node --import tsx scripts/ci/generate-legacy-capability-parity-report.ts --fixture-pack config/ci/legacy-capability-parity-fixture-pack.json --matrix config/ci/legacy-capability-matrix.json --out artifacts/bench/retrieval-parity-pr.json",
    "ci:archive:legacy-capability-parity-history": "node --import tsx scripts/ci/archive-legacy-capability-parity-history.ts --artifact artifacts/bench/legacy-capability-parity-gate.json --history-dir artifacts/bench/legacy-capability-parity-history",
    "ci:check:legacy-capability-parity:strict": "npm run -s ci:check:legacy-capability-parity && npm run -s ci:archive:legacy-capability-parity-history && node --import tsx scripts/ci/check-legacy-capability-parity.ts --report artifacts/bench/retrieval-parity-pr.json --matrix config/ci/legacy-capability-matrix.json --out artifacts/bench/legacy-capability-parity-gate.json --require-consecutive 3 --history-dir artifacts/bench/legacy-capability-parity-history",
    "ci:generate:retrieval-quality-telemetry": "node --import tsx scripts/ci/generate-retrieval-quality-telemetry.ts --out artifacts/bench/retrieval-quality-telemetry.json",
    "ci:check:retrieval-holdout-fixture": "node --import tsx scripts/ci/check-retrieval-holdout-fixture.ts --fixture-pack config/ci/retrieval-quality-fixture-pack.json --out artifacts/bench/retrieval-holdout-check.json",
    "ci:generate:retrieval-quality-report": "npm run -s ci:check:retrieval-holdout-fixture && npm run -s ci:generate:retrieval-quality-telemetry && node --import tsx scripts/ci/generate-retrieval-quality-report.ts --fixture-pack config/ci/retrieval-quality-fixture-pack.json --perf-profile quality --out artifacts/bench/retrieval-quality-report.json",
    "ci:check:retrieval-quality-gate": "npm run -s ci:generate:retrieval-quality-report && node --import tsx scripts/ci/check-retrieval-quality-gate.ts --report artifacts/bench/retrieval-quality-report.json --out artifacts/bench/retrieval-quality-gate.json",
    "ci:check:bench-mode-lock": "node --import tsx scripts/ci/check-bench-mode-lock.ts --baseline artifacts/bench/pr-baseline.json --candidate artifacts/bench/pr-candidate.json --out artifacts/bench/bench-mode-lock-gate.json --allow-modes retrieve,search",
    "ci:check:retrieval-shadow-canary-gate": "npm run -s ci:check:retrieval-quality-gate && node --import tsx scripts/ci/check-retrieval-shadow-canary-gate.ts --quality-report artifacts/bench/retrieval-quality-report.json --telemetry artifacts/bench/retrieval-quality-telemetry.json --holdout artifacts/bench/retrieval-holdout-check.json --out artifacts/bench/retrieval-shadow-canary-gate.json",
    "ci:generate:enhancement-error-taxonomy-report": "node --import tsx scripts/ci/generate-enhancement-error-taxonomy-report.ts --events artifacts/bench/enhancement-error-events.json --start-utc 1970-01-01T00:00:00.000Z --end-utc-exclusive 2100-01-01T00:00:00.000Z --max-transient-upstream 0 --max-auth-config 0 --max-quota 0 --max-unknown 0 --max-malformed 0 --out artifacts/bench/enhancement-error-taxonomy-report.json",
    "ci:check:enhancement-error-taxonomy-report": "npm run -s ci:generate:enhancement-error-taxonomy-report && node --import tsx scripts/ci/check-enhancement-error-taxonomy-report.ts --report artifacts/bench/enhancement-error-taxonomy-report.json",
    "ci:generate:weekly-retrieval-trend-report": "node --import tsx scripts/ci/generate-weekly-retrieval-trend-report.ts --parity artifacts/bench/legacy-capability-parity-gate.json --quality artifacts/bench/retrieval-quality-report.json --out artifacts/bench/r4-weekly-trend.json --archive-dir artifacts/bench/archive/r4-weekly --retention-weeks 12",
    "ci:check:weekly-retrieval-trend-report": "node --import tsx scripts/ci/check-weekly-retrieval-trend-report.ts --artifact artifacts/bench/r4-weekly-trend.json --archive-dir artifacts/bench/archive/r4-weekly",
    "ci:generate:semantic-latency-report": "node --import tsx scripts/ci/generate-semantic-latency-report.ts --out artifacts/bench/semantic-latency-report.json",
    "ci:check:enhance-prompt-contract": "node --import tsx scripts/ci/check-enhance-prompt-contract.ts",
    "ci:check:enhance-doc-contract": "node --import tsx scripts/ci/check-enhance-doc-contract.ts",
    "ci:check:r6-execution-board": "node --import tsx scripts/ci/check-r6-execution-board.ts",
    "ops:check:process-health": "powershell -ExecutionPolicy Bypass -File .\\scripts\\ops\\check-context-engine-process-health.ps1"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "openai-session",
    "context-engine",
    "semantic-search"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@lancedb/lancedb": "^0.27.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "apache-arrow": "^18.1.0",
    "chokidar": "^3.5.3",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "minimatch": "^10.1.1",
    "tree-sitter": "^0.21.1",
    "tree-sitter-typescript": "^0.23.2",
    "tsx": "^4.21.0",
    "yaml": "^2.3.0"
  },
  "devDependencies": {
    "@types/chokidar": "^2.1.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.3",
    "jest": "^30.2.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.0"
  }
}
