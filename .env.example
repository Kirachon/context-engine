# Preferred provider: OpenAI session via Codex CLI
# Run once before use: codex login
CE_AI_PROVIDER=openai_session
CE_OPENAI_SESSION_CMD=codex
# Wrapper/prefix args used for readiness + exec calls (typically empty unless using cmd wrapper)
CE_OPENAI_SESSION_ARGS_JSON=[]
# Exec-only args appended after "exec" (optional)
CE_OPENAI_SESSION_EXEC_ARGS_JSON=[]
CE_OPENAI_SESSION_REFRESH_MODE=per_call
CE_OPENAI_SESSION_IDENTITY_TTL_MS=30000
CE_OPENAI_SESSION_HEALTHCHECK_TIMEOUT_MS=10000
CE_AI_REQUEST_TIMEOUT_MS=120000
# Compatibility mode: true re-enables keyword fallback when provider explicitly returns []
CE_SEMANTIC_EMPTY_ARRAY_COMPAT_FALLBACK=false

# Workspace path (optional, can be passed via CLI)
WORKSPACE_PATH=/path/to/your/project

# Windows fallback (use if you get "command not found" in MCP runtime):
# CE_OPENAI_SESSION_CMD=cmd
# CE_OPENAI_SESSION_ARGS_JSON=["/d","/s","/c","D:\\npm-global\\codex.cmd"]
